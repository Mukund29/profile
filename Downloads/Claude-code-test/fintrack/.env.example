# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (from Supabase Auth → Google provider)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# RevenueCat (Sprint 3 — not needed for onboarding)
# EXPO_PUBLIC_REVENUECAT_API_KEY=your-rc-key

# Region (auto-detected from device locale — override for testing)
# EXPO_PUBLIC_FORCE_REGION=IN
